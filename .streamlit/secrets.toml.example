# Шаблон секретов Streamlit Cloud.
# Реальный secrets.toml не коммитится — задаётся в UI Streamlit Cloud:
# https://share.streamlit.io → ваш app → Settings → Secrets
#
# Скопируйте содержимое этого файла в Streamlit Cloud Secrets и подставьте реальные значения.

# --- Anthropic API ---
ANTHROPIC_API_KEY = "sk-ant-api03-..."
ANTHROPIC_MODEL_OPUS = "claude-opus-4-7"
ANTHROPIC_MODEL_HAIKU = "claude-haiku-4-5-20251001"

# --- База знаний (вшита в репо в knowledge_base/data/) ---
KNOWLEDGE_BASE_PATH = "./knowledge_base/data"

# --- Вывод ---
OUTPUT_DIR = "./output"
SQLITE_PATH = "./data/local.db"

# --- Пароль для входа ---
# Один пароль для всех пользователей. Поменять — обновите тут и сделайте Reboot app.
app_password = "Calltouch2026!"

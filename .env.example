# Скопируй этот файл в .env и заполни значения. .env в git не коммитится.

# --- LLM API ключи (Anthropic-only пайплайн) ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Модели по умолчанию ---
# Opus 4.7 — творческая часть (сценарии, ревью, итоговая сборка)
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
# Haiku 4.5 — дешёвая часть (парсинг сайта, разбор брифа)
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# --- Пути ---
KNOWLEDGE_BASE_PATH=../cdp_calltouch_kb
OUTPUT_DIR=./output

# --- Headless Chrome для PDF ---
# Можно указать путь к chrome.exe или msedge.exe.
# Пусто = автодетект (пробуем Chrome → Edge → fallback на сохранение HTML).
CHROME_PATH=

# --- SQLite (фаза 1) ---
SQLITE_PATH=./data/local.db

# =============================================================================
# Ниже — заглушки для фазы 2 (не нужны в локальной разработке)
# =============================================================================

